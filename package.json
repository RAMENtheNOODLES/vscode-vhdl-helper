{
  "name": "vhdl-helper",
  "displayName": "VHDL Helper",
  "description": "VHDL snippets + a language server",
  "version": "1.0.1",
  "publisher": "CookieJAR499",
  "repository": {
    "type": "git",
    "url": "https://github.com/RAMENtheNOODLES/vscode-vhdl-helper"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Snippets",
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:vhdl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "vhdl",
        "aliases": [
          "VHDL",
          "vhdl"
        ],
        "extensions": [
          ".vhd",
          ".vhdl",
          ".vho",
          ".vht"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vhdl",
        "scopeName": "source.vhdl",
        "path": "./syntaxes/vhdl.tmLanguage"
      }
    ],
    "snippets": [
      {
        "language": "vhdl",
        "path": "./snippets/vhdl_snippets.json"
      }
    ],
    "commands": [
      {
        "command": "vhdlHelper.clipboardComponentToDut",
        "title": "VHDL Helper: Clipboard COMPONENT → DUT PORT MAP"
      },
      {
        "command": "vhdlHelper.clipboardComponentToSignals",
        "title": "VHDL Helper: Clipboard COMPONENT → SIGNAL declarations"
      }
    ],
    "keybindings": [
      {
        "command": "vhdlHelper.clipboardComponentToSignals",
        "key": "ctrl+alt+s",
        "when": "editorTextFocus && editorLangId == vhdl"
      },
      {
        "command": "vhdlHelper.clipboardComponentToDut",
        "key": "ctrl+alt+d",
        "when": "editorTextFocus && editorLangId == vhdl"
      }
    ],
    "configuration": [
      {
        "title": "VHDL Helper",
        "properties": {
          "vhdlHelper.authorName": {
            "type": "string",
            "default": "",
            "description": "Default author name used in the VHDL header snippet."
          },
          "vhdlHelper.courseName": {
            "type": "string",
            "default": "",
            "description": "Default course name used in the VHDL header snippet."
          }
        }
      },
      {
        "title": "VHDL",
        "properties": {
          "vhdl.languageStandard": {
            "type": "string",
            "enum": ["87", "93", "02", "08", "19"],
            "default": "08",
            "description": "VHDL language standard to use."
          },
          "vhdl.diagnostics.mode": {
            "type": "string",
            "enum": ["basic", "ghdl", "both", "off"],
            "default": "both",
            "description": "Diagnostics mode: basic (syntax only), ghdl (GHDL-based), both, or off."
          },
          "vhdl.ghdl.path": {
            "type": "string",
            "default": "",
            "description": "Path to the GHDL executable. Leave empty to use PATH."
          },
          "vhdl.ghdl.args": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "Extra command-line arguments passed to GHDL."
          },
          "vhdl.ghdl.run": {
            "type": "string",
            "enum": ["onSave", "onType"],
            "default": "onSave",
            "description": "When to run GHDL: on save or on type."
          },
          "vhdl.ghdl.debounceMs": {
            "type": "number",
            "default": 500,
            "description": "Debounce delay (ms) before running GHDL diagnostics on type."
          },
          "vhdl.workspace.sourceGlobs": {
            "type": "array",
            "items": { "type": "string" },
            "default": ["**/*.vhd", "**/*.vhdl", "**/*.vho", "**/*.vht"],
            "description": "Glob patterns for VHDL source files included in the workspace."
          }
        }
      }
    ]
  },
  "capabilities": {
    "completionProvider": {
      "resolveProvider": "true",
      "triggerCharacters": [
        "."
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vhdl-language-server": "^0.3.0"
  }
}
