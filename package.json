{
  "name": "vhdl-helper",
  "displayName": "VHDL Helper (Snippets + COMPONENT→DUT)",
  "description": "VHDL snippets plus a command that converts clipboard COMPONENT declarations into DUT PORT MAP text in the editor.",
  "version": "0.0.9",
  "publisher": "CookieJAR499",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Snippets",
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:vhdl",
    "onCommand:vhdlHelper.clipboardComponentToDut",
    "onCommand:vhdlHelper.clipboardComponentToSignals"
  ],
  "contributes": {
    "snippets": [
      {
        "language": "vhdl",
        "path": "./snippets/vhdl_snippets.json"
      }
    ],
    "commands": [
      {
        "command": "vhdlHelper.clipboardComponentToDut",
        "title": "VHDL Helper: Clipboard COMPONENT → DUT PORT MAP"
      },
      {
        "command": "vhdlHelper.clipboardComponentToSignals",
        "title": "VHDL Helper: Clipboard COMPONENT → SIGNAL declarations"
      }
    ],
    "keybindings": [
      {
        "command": "vhdlHelper.clipboardComponentToSignals",
        "key": "ctrl+alt+s",
        "when": "editorTextFocus && editorLangId == vhdl"
      },
      {
        "command": "vhdlHelper.clipboardComponentToDut",
        "key": "ctrl+alt+d",
        "when": "editorTextFocus && editorLangId == vhdl"
      }
    ],
    "configuration": {
      "title": "VHDL Helper",
      "properties": {
        "vhdlHelper.authorName": {
          "type": "string",
          "default": "",
          "description": "Default author name used in the VHDL header snippet."
        },
        "vhdlHelper.courseName": {
          "type": "string",
          "default": "",
          "description": "Default course name used in the VHDL header snippet."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vsce": "^2.15.0"
  }
}
